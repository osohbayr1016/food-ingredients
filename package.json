{
  "name": "food-ingredients",
  "private": true,
  "packageManager": "pnpm@10.33.3",
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "sharp", "workerd", "unrs-resolver"],
    "patchedDependencies": {
      "@cloudflare/next-on-pages@1.13.16": "patches/@cloudflare__next-on-pages@1.13.16.patch"
    }
  },
  "scripts": {
    "db:reset": "pnpm --filter api run db:reset",
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm run cf:pages-build",
    "build:api": "pnpm --filter api run build",
    "lint": "pnpm -r run lint",
    "cf:pages-build": "node apps/web/scripts/patchWranglerPagesUpload.mjs && pnpm --filter web run pages:build",
    "deploy": "pnpm --filter web exec wrangler pages deploy .vercel/output/static"
  }
}
