{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:turbo": "next dev --turbopack",
    "build": "next build",
    "pages:build": "next build && CF_PAGES_BUILD=1 next-on-pages && node ./scripts/patchNextOnPagesOutput.mjs && node ./scripts/writeAssetsIgnore.mjs",
    "cf:deploy": "pnpm run pages:build && wrangler deploy",
    "pages:deploy": "pnpm run cf:deploy",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@xenova/transformers": "^2.17.2",
    "next": "15.5.16",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.16",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.88.0"
  }
}
